{% extends 'layout-auth.twig' %}
{% block title %}Token ungültig – {{ org.short_name }}{% endblock %}
{% block content %}
<div class="w-full max-w-xl text-center">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-amber-100 text-amber-700 mb-6">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 9v4M12 17h.01M21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/></svg>
    </div>
    <h1 class="text-2xl font-bold tracking-tight mb-3">Approval-Link ungültig</h1>
    <p class="text-gray-600 max-w-md mx-auto mb-2">{{ reason }}</p>
    <p class="text-sm text-gray-500">
        Bitte den/die Antragsteller:in bitten, einen neuen Antrag zu stellen.
    </p>
</div>
{% endblock %}
