{% extends 'layout-auth.twig' %}
{% block title %}{{ (action == 'approve' ? 'status.aktiv.urlaub' : 'status.abgelehnt')|trans }} – {{ org.short_name }}{% endblock %}
{% block content %}
<div class="w-full max-w-xl text-center">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full {{ action == 'approve' ? 'bg-sage-100 text-sage-700' : 'bg-red-100 text-red-700' }} mb-6">
        {% if action == 'approve' %}
        <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
        {% else %}
        <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
        {% endif %}
    </div>
    <h1 class="text-3xl font-bold tracking-tight mb-3">
        {{ (action == 'approve' ? 'approval.done.approved.heading' : 'approval.done.rejected.heading')|trans }}
    </h1>
    <p class="text-gray-600 max-w-md mx-auto">
        {% if action == 'approve' %}
        {{ 'approval.done.approved.body'|trans({'%name%': applicant.display_name}) }}
        {% else %}
        {{ 'approval.done.rejected.body'|trans({'%name%': applicant.display_name}) }}
        {% endif %}
    </p>
</div>
{% endblock %}
