{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">{{ 'setup.provider.heading'|trans }}</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    {{ 'setup.provider.body'|trans }}
</p>

<form method="post" action="/setup/provider" class="space-y-4">
    <label class="block border border-gray-300 rounded-lg p-5 cursor-pointer hover:border-primary has-[:checked]:border-primary has-[:checked]:bg-primary/5">
        <div class="flex items-start gap-3">
            <input type="radio" name="identity_provider" value="microsoft" class="mt-1"
                   {% if env.IDENTITY_PROVIDER == 'microsoft' or env.IDENTITY_PROVIDER is empty %}checked{% endif %}>
            <div>
                <strong class="block text-base">{{ 'setup.provider.microsoft.label'|trans }}</strong>
                <span class="text-sm text-gray-600 leading-relaxed">
                    {{ 'setup.provider.microsoft.body'|trans }}
                </span>
            </div>
        </div>
    </label>

    <label class="block border border-gray-300 rounded-lg p-5 cursor-pointer hover:border-primary has-[:checked]:border-primary has-[:checked]:bg-primary/5">
        <div class="flex items-start gap-3">
            <input type="radio" name="identity_provider" value="google" class="mt-1"
                   {% if env.IDENTITY_PROVIDER == 'google' %}checked{% endif %}>
            <div>
                <strong class="block text-base">{{ 'setup.provider.google.label'|trans }}</strong>
                <span class="text-sm text-gray-600 leading-relaxed">
                    {{ 'setup.provider.google.body'|trans }}
                </span>
            </div>
        </div>
    </label>

    <div class="flex justify-between pt-3">
        <a href="/setup" class="btn btn-ghost">{{ 'setup.action.back'|trans }}</a>
        <button type="submit" class="btn btn-primary">{{ 'setup.action.next'|trans }}</button>
    </div>
</form>
{% endblock %}
