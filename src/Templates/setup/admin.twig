{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">{{ 'setup.admin.heading'|trans }}</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    {{ 'setup.admin.body'|trans|raw }}
</p>

<form method="post" action="/setup/admin" class="space-y-5">
    <div>
        <label class="label"><span class="label-text">{{ 'setup.admin.field.email'|trans }}</span></label>
        <input type="email" name="email" required class="input input-bordered w-full"
               placeholder="admin@your-company.com">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.admin.field.email.hint'|trans }}
        </p>
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.admin.field.display_name'|trans }}</span></label>
        <input type="text" name="display_name" required class="input input-bordered w-full"
               placeholder="First Last">
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.admin.field.job_title'|trans }}</span></label>
        <input type="text" name="job_title" class="input input-bordered w-full"
               placeholder="{{ 'setup.admin.field.job_title.placeholder'|trans }}">
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-md px-4 py-3 text-sm">
        {{ 'setup.admin.info'|trans|raw }}
    </div>

    <div class="flex justify-between pt-3">
        <a href="/setup/smtp" class="btn btn-ghost">{{ 'setup.action.back'|trans }}</a>
        <button type="submit" class="btn btn-primary">{{ 'setup.admin.submit'|trans }}</button>
    </div>
</form>
{% endblock %}
