{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">Admin-Konto</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    Lege das erste HR + Genehmiger-Konto an. Die <code>entra_oid</code>
    bleibt zunächst leer und wird beim ersten SSO-Login automatisch über die
    Email gematched.
</p>

<form method="post" action="/setup/admin" class="space-y-5">
    <div>
        <label class="label"><span class="label-text">Email (M365-Login)</span></label>
        <input type="email" name="email" required class="input input-bordered w-full"
               placeholder="admin@eure-firma.de">
        <p class="text-xs text-gray-500 mt-1">
            Genau die Email mit der sich die Person später per SSO einloggt.
        </p>
    </div>

    <div>
        <label class="label"><span class="label-text">Anzeigename</span></label>
        <input type="text" name="display_name" required class="input input-bordered w-full"
               placeholder="Vorname Nachname">
    </div>

    <div>
        <label class="label"><span class="label-text">Job-Titel (optional)</span></label>
        <input type="text" name="job_title" class="input input-bordered w-full"
               placeholder="z.B. Head of People">
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-md px-4 py-3 text-sm">
        Der angelegte User ist sofort <strong>HR</strong> und <strong>Genehmiger</strong>.
        Weitere Mitarbeiter können danach in der App unter <code>/hr/users</code>
        angelegt werden.
    </div>

    <div class="flex justify-between pt-3">
        <a href="/setup/smtp" class="btn btn-ghost">← Zurück</a>
        <button type="submit" class="btn btn-primary">Konto anlegen + weiter →</button>
    </div>
</form>
{% endblock %}
