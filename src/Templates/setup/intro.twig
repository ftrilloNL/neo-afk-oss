{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">{{ 'setup.intro.heading'|trans }}</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    {{ 'setup.intro.body'|trans }}
</p>

<ul class="space-y-3 mb-8">
    {% for i in [1, 2, 3, 4] %}
    <li class="flex gap-3">
        <span class="mt-0.5 w-5 h-5 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center shrink-0">{{ i }}</span>
        <div>
            <strong class="block">{{ ('setup.intro.req' ~ i ~ '.title')|trans|raw }}</strong>
            <span class="text-sm text-gray-600">
                {{ ('setup.intro.req' ~ i ~ '.body')|trans|raw }}
            </span>
        </div>
    </li>
    {% endfor %}
</ul>

<div class="bg-yellow-50 border border-yellow-200 rounded-md px-4 py-3 mb-6 text-sm">
    {{ 'setup.intro.security_warning'|trans|raw }}
</div>

<div class="flex justify-end">
    <a href="/setup/provider" class="btn btn-primary">{{ 'setup.intro.start_btn'|trans }}</a>
</div>
{% endblock %}
