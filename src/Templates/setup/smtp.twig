{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">E-Mail-Versand</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    SMTP via XOAUTH2 gegen das „noreply"-Postfach. Wir holen einen
    Refresh-Token via Device-Code-Flow — du loggst dich kurz in einem
    neuen Tab ein, kommst zurück, fertig.
</p>

{% if device_flow is null or device_flow.status == 'expired' or device_flow.status == 'error' %}
<form method="post" action="/setup/smtp" class="space-y-5">
    <div class="grid grid-cols-3 gap-3">
        <div class="col-span-2">
            <label class="label"><span class="label-text">SMTP-Host</span></label>
            <input type="text" name="smtp_host" required class="input input-bordered w-full"
                   value="{{ env.SMTP_HOST ?? 'smtp.office365.com' }}">
        </div>
        <div>
            <label class="label"><span class="label-text">Port</span></label>
            <input type="text" name="smtp_port" required class="input input-bordered w-full"
                   value="{{ env.SMTP_PORT ?? '587' }}">
        </div>
    </div>

    <div>
        <label class="label"><span class="label-text">From-Email (lizenziertes Postfach)</span></label>
        <input type="email" name="smtp_from_email" required class="input input-bordered w-full"
               placeholder="noreply@eure-firma.de"
               value="{{ env.SMTP_FROM_EMAIL ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            Muss ein <strong>lizenziertes User-Postfach</strong> sein
            (Shared Mailboxes können kein SMTP-Auth). Authentifiziertes SMTP
            muss für diese Mailbox im Admin-Center aktiviert sein.
        </p>
    </div>

    <div>
        <label class="label"><span class="label-text">From-Name (Absender-Anzeige)</span></label>
        <input type="text" name="smtp_from_name" required class="input input-bordered w-full"
               placeholder="afk"
               value="{{ env.SMTP_FROM_NAME ?? env.ORG_NAME ?? '' }}">
    </div>

    <div class="flex justify-between pt-3">
        <a href="/setup/oauth" class="btn btn-ghost">← Zurück</a>
        <button type="submit" class="btn btn-primary">Device-Code holen →</button>
    </div>
</form>

{% else %}
    {# Device-Code-Flow aktiv #}
    <div id="device-pending" class="space-y-5" data-poll-interval="{{ device_flow.interval }}">
        <div class="bg-primary/10 border-2 border-primary rounded-lg p-5">
            <p class="text-sm font-medium mb-2">1. Öffne diesen Link in einem neuen Tab:</p>
            <a href="{{ device_flow.verification_uri }}" target="_blank"
               class="text-primary font-medium underline break-all">
                {{ device_flow.verification_uri }}
            </a>

            <p class="text-sm font-medium mt-4 mb-2">2. Gib diesen Code ein:</p>
            <div class="bg-white border border-primary rounded-md px-4 py-3 font-mono text-2xl tracking-widest text-center font-bold">
                {{ device_flow.user_code }}
            </div>

            <p class="text-sm font-medium mt-4 mb-2">
                3. Logge dich als <code>{{ env.SMTP_FROM_EMAIL }}</code> ein
                und bestätige die SMTP.Send-Berechtigung.
            </p>
        </div>

        <div id="poll-status" class="flex items-center gap-3 text-sm text-gray-600">
            <span class="inline-block w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
            <span>Warte auf Autorisierung…</span>
        </div>

        <div id="poll-error" class="hidden bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-800"></div>

        <form id="continue-form" method="post" action="/setup/smtp/continue" class="hidden">
            <div class="bg-green-50 border border-green-200 rounded-md px-4 py-3 text-sm text-green-800 mb-4">
                <strong>✓ Erfolgreich autorisiert.</strong> Refresh-Token gespeichert.
            </div>
            <div class="flex justify-end">
                <button type="submit" class="btn btn-primary">Weiter →</button>
            </div>
        </form>

        <form method="post" action="/setup/smtp" class="hidden" id="restart-form">
            <input type="hidden" name="smtp_host" value="{{ env.SMTP_HOST }}">
            <input type="hidden" name="smtp_port" value="{{ env.SMTP_PORT }}">
            <input type="hidden" name="smtp_from_email" value="{{ env.SMTP_FROM_EMAIL }}">
            <input type="hidden" name="smtp_from_name" value="{{ env.SMTP_FROM_NAME }}">
            <button type="submit" class="btn btn-outline">Neuen Code holen</button>
        </form>
    </div>
{% endif %}
{% endblock %}

{% block scripts %}
{% if device_flow is not null and device_flow.status == 'pending' %}
<script src="/assets/setup-poll.js"></script>
{% endif %}
{% endblock %}
