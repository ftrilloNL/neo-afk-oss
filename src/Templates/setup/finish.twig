{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">{{ 'setup.finish.heading'|trans }}</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    {{ 'setup.finish.body'|trans }}
</p>

<h2 class="text-base font-semibold mb-2 mt-6">{{ 'setup.finish.cron.heading'|trans }}</h2>
<p class="text-sm text-gray-600 mb-3 leading-relaxed">
    {{ 'setup.finish.cron.body'|trans }}
</p>
<pre class="bg-gray-50 border border-gray-200 rounded-md px-4 py-3 text-xs font-mono overflow-x-auto"><code>0 2 * * *   php /path/to/app/cron/cleanup-tokens.php
0 6 * * *   php /path/to/app/cron/ooo-sync.php
0 9 * * *   php /path/to/app/cron/reminders.php
0 2 1 1 *   php /path/to/app/cron/jahreswechsel.php
0 2 1 4 *   php /path/to/app/cron/verfall.php</code></pre>

<h2 class="text-base font-semibold mb-2 mt-6">{{ 'setup.finish.logo.heading'|trans }}</h2>
<p class="text-sm text-gray-600 mb-3 leading-relaxed">
    {{ 'setup.finish.logo.body'|trans|raw }}
</p>

<h2 class="text-base font-semibold mb-2 mt-6">{{ 'setup.finish.lock.heading'|trans }}</h2>
<p class="text-sm text-gray-600 mb-4 leading-relaxed">
    {{ 'setup.finish.lock.body'|trans|raw }}
</p>

<form method="post" action="/setup/finish">
    <div class="flex justify-end gap-3">
        <button type="submit" class="btn btn-primary">{{ 'setup.finish.submit'|trans }}</button>
    </div>
</form>
{% endblock %}
