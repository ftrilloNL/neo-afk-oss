{% extends 'setup/layout.twig' %}

{% block content %}
{% if provider == 'microsoft' %}
<h1 class="text-2xl font-bold mb-2">{{ 'setup.oauth.ms.heading'|trans }}</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    {{ 'setup.oauth.ms.body'|trans|raw }}
</p>

<div class="bg-blue-50 border border-blue-200 rounded-md px-4 py-3 mb-6 text-sm">
    <strong>{{ 'setup.oauth.redirect_label'|trans }}</strong>
    <code class="block mt-1 break-all">{{ env.APP_URL ?? 'https://afk.your-company.com' }}/auth/callback</code>
</div>

<form method="post" action="/setup/oauth" class="space-y-5">
    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.ms.field.tenant'|trans }}</span></label>
        <input type="text" name="oauth_tenant_id" required class="input input-bordered w-full"
               placeholder="00000000-0000-0000-0000-000000000000"
               value="{{ env.OAUTH_TENANT_ID ?? '' }}">
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.ms.field.client_id'|trans }}</span></label>
        <input type="text" name="oauth_client_id" required class="input input-bordered w-full"
               placeholder="00000000-0000-0000-0000-000000000000"
               value="{{ env.OAUTH_CLIENT_ID ?? '' }}">
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.ms.field.client_secret'|trans }}</span></label>
        <input type="password" name="oauth_client_secret" required class="input input-bordered w-full"
               value="{{ env.OAUTH_CLIENT_SECRET ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.ms.field.client_secret.hint'|trans|raw }}
        </p>
    </div>

    <hr class="my-2 border-gray-200">

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.field.shared_mailbox'|trans }}</span></label>
        <input type="email" name="graph_calendar_user" required class="input input-bordered w-full"
               placeholder="vacation@your-company.com"
               value="{{ env.GRAPH_CALENDAR_USER ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.field.shared_mailbox.hint'|trans }}
        </p>
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.field.hr_email'|trans }}</span></label>
        <input type="text" name="hr_notification_email" required class="input input-bordered w-full"
               placeholder="hr@your-company.com"
               value="{{ env.HR_NOTIFICATION_EMAIL ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.field.hr_email.hint'|trans }}
        </p>
    </div>

    <div class="flex justify-between pt-3">
        <a href="/setup/org" class="btn btn-ghost">{{ 'setup.action.back'|trans }}</a>
        <button type="submit" class="btn btn-primary">{{ 'setup.action.next'|trans }}</button>
    </div>
</form>

{% else %}
<h1 class="text-2xl font-bold mb-2">{{ 'setup.oauth.google.heading'|trans }}</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    {{ 'setup.oauth.google.body'|trans|raw }}
</p>

<div class="bg-blue-50 border border-blue-200 rounded-md px-4 py-3 mb-6 text-sm">
    <strong>{{ 'setup.oauth.google.redirect_label'|trans }}</strong>
    <code class="block mt-1 break-all">{{ env.APP_URL ?? 'https://afk.your-company.com' }}/auth/callback</code>
</div>

<form method="post" action="/setup/oauth" enctype="multipart/form-data" class="space-y-5">

    <h2 class="text-base font-semibold border-b pb-2">{{ 'setup.oauth.google.section.oauth'|trans }}</h2>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.google.field.client_id'|trans }}</span></label>
        <input type="text" name="oauth_client_id" required class="input input-bordered w-full"
               placeholder="000000000000-xxxxxxxxxxxx.apps.googleusercontent.com"
               value="{{ env.OAUTH_CLIENT_ID ?? '' }}">
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.google.field.client_secret'|trans }}</span></label>
        <input type="password" name="oauth_client_secret" required class="input input-bordered w-full"
               value="{{ env.OAUTH_CLIENT_SECRET ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.google.field.client_secret.hint'|trans }}
        </p>
    </div>

    <h2 class="text-base font-semibold border-b pb-2 pt-4">{{ 'setup.oauth.google.section.service_account'|trans }}</h2>

    <div>
        <label class="label">
            <span class="label-text">
                {{ 'setup.oauth.google.field.service_account_json'|trans }}
                {% if service_account_present %}
                    <span class="text-xs text-green-700 font-normal">{{ 'setup.oauth.google.field.service_account_json.already_uploaded'|trans }}</span>
                {% endif %}
            </span>
        </label>
        <input type="file" name="service_account_json" accept="application/json"
               class="file-input file-input-bordered w-full"
               {% if not service_account_present %}required{% endif %}>
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.google.field.service_account_json.hint'|trans|raw }}
        </p>
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.google.field.workspace_domain'|trans }}</span></label>
        <input type="text" name="google_workspace_domain" required class="input input-bordered w-full"
               placeholder="your-company.com"
               value="{{ env.GOOGLE_WORKSPACE_DOMAIN ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.google.field.workspace_domain.hint'|trans }}
        </p>
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.google.field.calendar_id'|trans }}</span></label>
        <input type="text" name="google_calendar_id" required class="input input-bordered w-full"
               placeholder="vacation@your-company.com  or  xyz@group.calendar.google.com"
               value="{{ env.GOOGLE_CALENDAR_ID ?? '' }}">
    </div>

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.google.field.calendar_owner'|trans }}</span></label>
        <input type="email" name="google_calendar_owner" required class="input input-bordered w-full"
               placeholder="vacation@your-company.com"
               value="{{ env.GOOGLE_CALENDAR_OWNER ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.google.field.calendar_owner.hint'|trans }}
        </p>
    </div>

    <hr class="my-2 border-gray-200">

    <div>
        <label class="label"><span class="label-text">{{ 'setup.oauth.field.hr_email'|trans }}</span></label>
        <input type="text" name="hr_notification_email" required class="input input-bordered w-full"
               placeholder="hr@your-company.com"
               value="{{ env.HR_NOTIFICATION_EMAIL ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            {{ 'setup.oauth.field.hr_email.hint'|trans }}
        </p>
    </div>

    <div class="flex justify-between pt-3">
        <a href="/setup/org" class="btn btn-ghost">{{ 'setup.action.back'|trans }}</a>
        <button type="submit" class="btn btn-primary">{{ 'setup.action.next'|trans }}</button>
    </div>
</form>
{% endif %}
{% endblock %}
