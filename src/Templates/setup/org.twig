{% extends 'setup/layout.twig' %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">Organisation</h1>
<p class="text-gray-600 mb-6 leading-relaxed">
    Branding und Default-Werte für eure Instanz.
</p>

<form method="post" action="/setup/org" class="space-y-5">
    <div>
        <label class="label"><span class="label-text">APP_URL — öffentliche Adresse der App</span></label>
        <input type="url" name="app_url" required class="input input-bordered w-full"
               placeholder="https://afk.eure-firma.de"
               value="{{ env.APP_URL ?? '' }}">
        <p class="text-xs text-gray-500 mt-1">
            Wird als Redirect-URI für M365-OAuth verwendet
            (<code>APP_URL/auth/callback</code>) und in Mails verlinkt.
        </p>
    </div>

    <div class="grid grid-cols-2 gap-3">
        <div>
            <label class="label"><span class="label-text">ORG_NAME (Anzeigename)</span></label>
            <input type="text" name="org_name" required class="input input-bordered w-full"
                   placeholder="afk"
                   value="{{ env.ORG_NAME ?? '' }}">
        </div>
        <div>
            <label class="label"><span class="label-text">ORG_SHORT_NAME (Tab / Mobile)</span></label>
            <input type="text" name="org_short_name" required class="input input-bordered w-full"
                   placeholder="afk"
                   value="{{ env.ORG_SHORT_NAME ?? '' }}">
        </div>
    </div>

    <div>
        <label class="label"><span class="label-text">ORG_LEGAL_NAME (im Footer)</span></label>
        <input type="text" name="org_legal_name" required class="input input-bordered w-full"
               placeholder="Eure Firma GmbH"
               value="{{ env.ORG_LEGAL_NAME ?? '' }}">
    </div>

    <div class="grid grid-cols-2 gap-3">
        <div>
            <label class="label"><span class="label-text">Support-Email</span></label>
            <input type="email" name="org_support_email" required class="input input-bordered w-full"
                   placeholder="it@eure-firma.de"
                   value="{{ env.ORG_SUPPORT_EMAIL ?? '' }}">
        </div>
        <div>
            <label class="label"><span class="label-text">Akzentfarbe (HEX)</span></label>
            <input type="text" name="org_accent_color" required class="input input-bordered w-full"
                   placeholder="#3b82f6"
                   pattern="^#[0-9a-fA-F]{6}$"
                   value="{{ env.ORG_ACCENT_COLOR_HEX ?? '#3b82f6' }}">
        </div>
    </div>

    <div>
        <label class="label"><span class="label-text">Default-Urlaubsanspruch (Tage/Jahr)</span></label>
        <input type="number" name="default_jahresanspruch" required min="1" max="50"
               class="input input-bordered w-full"
               value="{{ env.ORG_DEFAULT_JAHRESANSPRUCH ?? '30' }}">
        <p class="text-xs text-gray-500 mt-1">
            Wird beim Anlegen neuer MA als Vorschlag genutzt — pro User in HR anpassbar.
        </p>
    </div>

    <div class="flex justify-between pt-3">
        <a href="/setup/db" class="btn btn-ghost">← Zurück</a>
        <button type="submit" class="btn btn-primary">Weiter →</button>
    </div>
</form>
{% endblock %}
