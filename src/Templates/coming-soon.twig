{% extends 'layout.twig' %}
{% block title %}{{ title }} – {{ org.short_name }}{% endblock %}
{% block content %}
<div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold tracking-tight">{{ title }}</h1>
</div>

<div class="bg-white border border-card-border rounded-xl p-12 text-center">
    <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-sage-100 mb-4">
        <svg class="w-6 h-6 text-sage-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
        </svg>
    </div>
    <h2 class="text-lg font-semibold mb-2">Bald verfügbar</h2>
    <p class="text-gray-600 max-w-md mx-auto">
        Dieser Bereich kommt im nächsten Code-Commit. {{ note ?? '' }}
    </p>
    <a href="/" class="inline-flex items-center gap-2 mt-6 text-sm text-sage-700 hover:text-sage-800 font-medium underline underline-offset-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Zurück zur Übersicht
    </a>
</div>
{% endblock %}
