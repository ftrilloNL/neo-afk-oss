<!DOCTYPE html>
<html lang="{{ current_locale() }}">
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#FAFAF9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1A1A1A;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;padding:32px 16px;">
<tr><td align="center">
    <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#FFFFFF;border:1px solid #E5E5E0;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:32px;">
            <h1 style="margin:0 0 16px 0;font-size:18px;font-weight:700;color:#000000;">{{ 'mail.storno.notif_genehmiger.heading'|trans }}</h1>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">{{ 'mail.common.greeting'|trans({'%name%': genehmiger.display_name|split(' ')|first}) }}</p>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {% set is_self = canceller.id == applicant.id %}
                {% set key_prefix = is_self ? 'mail.storno.notif_genehmiger.body.self_' : 'mail.storno.notif_genehmiger.body.by_other_' %}
                {{ (key_prefix ~ absence.art)|trans({
                    '%applicant%': '<strong>' ~ applicant.display_name ~ '</strong>',
                    '%canceller%': '<strong>' ~ canceller.display_name ~ '</strong>',
                    '%start%': absence.startdatum|localized_date,
                    '%end%': absence.enddatum|localized_date,
                    '%days%': absence.tage_gezaehlt|number_format(1, ',', '.'),
                })|raw }}
            </p>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {% if absence.art == 'urlaub' and absence.status == 'aktiv' %}
                {{ 'mail.storno.notif_genehmiger.calendar_note_with_refund'|trans }}
                {% else %}
                {{ 'mail.storno.notif_genehmiger.calendar_note'|trans }}
                {% endif %}
            </p>
            <p style="margin:0 0 16px 0;font-size:13px;line-height:1.6;color:#6B6B6B;">
                {{ 'mail.storno.notif_genehmiger.info_only'|trans }}
            </p>
        </td></tr>

        <tr><td style="padding:16px 32px;background:#FAFAF9;border-top:1px solid #E5E5E0;font-size:11px;color:#6B6B6B;line-height:1.5;text-align:center;">
            {{ 'mail.common.footer.legal'|trans({'%short_name%': org.short_name, '%legal_name%': org.legal_name}) }}
        </td></tr>
    </table>
</td></tr>
</table>
</body>
</html>
