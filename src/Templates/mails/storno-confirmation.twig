<!DOCTYPE html>
<html lang="{{ current_locale() }}">
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#FAFAF9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1A1A1A;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;padding:32px 16px;">
<tr><td align="center">
    <table role="presentation" width="520" cellpadding="0" cellspacing="0" style="background:#FFFFFF;border:1px solid #E5E5E0;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:32px;">
            <h1 style="margin:0 0 16px 0;font-size:18px;font-weight:700;color:#000000;">{{ 'mail.storno.confirmation.heading'|trans }}</h1>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">{{ 'mail.common.greeting'|trans({'%name%': applicant.display_name|split(' ')|first}) }}</p>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {{ (absence.art == 'urlaub' ? 'mail.storno.confirmation.body.urlaub' : 'mail.storno.confirmation.body.krank')|trans({
                    '%start%': absence.startdatum|localized_date,
                    '%end%': absence.enddatum|localized_date,
                })|raw }}
            </p>
            {% if absence.art == 'urlaub' and absence.status == 'aktiv' %}
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {{ 'mail.storno.confirmation.refund_note'|trans }}
            </p>
            {% endif %}
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {{ 'mail.storno.confirmation.calendar_removed'|trans }}
            </p>
        </td></tr>

        <tr><td style="padding:16px 32px;background:#FAFAF9;border-top:1px solid #E5E5E0;font-size:11px;color:#6B6B6B;line-height:1.5;text-align:center;">
            {{ 'mail.common.footer.legal'|trans({'%short_name%': org.short_name, '%legal_name%': org.legal_name}) }}
        </td></tr>
    </table>
</td></tr>
</table>
</body>
</html>
