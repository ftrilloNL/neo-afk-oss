<!DOCTYPE html>
<html lang="{{ current_locale() }}">
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#FAFAF9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1A1A1A;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;padding:32px 16px;">
<tr><td align="center">
    <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#FFFFFF;border:1px solid #E5E5E0;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:32px;">
            <h1 style="margin:0 0 16px 0;font-size:18px;font-weight:700;color:#000000;">{{ 'mail.antrag_edited_genehmiger.heading'|trans }}</h1>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">{{ 'mail.common.greeting'|trans({'%name%': genehmiger.display_name|split(' ')|first}) }}</p>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {{ 'mail.antrag_edited_genehmiger.intro'|trans({
                    '%editor%': '<strong>' ~ editor.display_name ~ '</strong>',
                    '%applicant%': '<strong>' ~ applicant.display_name ~ '</strong>',
                })|raw }}
            </p>

            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;border-left:3px solid #7B9468;margin-bottom:20px;">
                <tr><td style="padding:14px 18px;">
                    <div style="font-size:12px;color:#6B6B6B;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">{{ 'mail.antrag_edited_genehmiger.before'|trans }}</div>
                    <div style="font-size:14px;color:#1A1A1A;line-height:1.5;">
                        {{ 'mail.antrag_edited_genehmiger.period_with_days'|trans({
                            '%start%': absence_old.startdatum|localized_date,
                            '%end%': absence_old.enddatum|localized_date,
                            '%days%': absence_old.tage_gezaehlt|number_format(1, ',', '.'),
                        }) }}
                    </div>
                </td></tr>
            </table>

            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#F0F4ED;border-left:3px solid #5D7A4C;margin-bottom:24px;">
                <tr><td style="padding:14px 18px;">
                    <div style="font-size:12px;color:#5D7A4C;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">{{ 'mail.antrag_edited_genehmiger.now'|trans }}</div>
                    <div style="font-size:14px;color:#1A1A1A;line-height:1.5;">
                        {{ 'mail.antrag_edited_genehmiger.period_with_days'|trans({
                            '%start%': absence_new.startdatum|localized_date,
                            '%end%': absence_new.enddatum|localized_date,
                            '%days%': absence_new.tage_gezaehlt|number_format(1, ',', '.'),
                        }) }}
                    </div>
                </td></tr>
            </table>

            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {{ 'mail.antrag_edited_genehmiger.calendar_updated'|trans }}
            </p>
            <p style="margin:0 0 16px 0;font-size:13px;line-height:1.6;color:#6B6B6B;">
                {{ 'mail.antrag_edited_genehmiger.info_only'|trans }}
            </p>
        </td></tr>

        <tr><td style="padding:16px 32px;background:#FAFAF9;border-top:1px solid #E5E5E0;font-size:11px;color:#6B6B6B;line-height:1.5;text-align:center;">
            {{ 'mail.common.footer.legal'|trans({'%short_name%': org.short_name, '%legal_name%': org.legal_name}) }}
        </td></tr>
    </table>
</td></tr>
</table>
</body>
</html>
