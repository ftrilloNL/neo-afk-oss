<!DOCTYPE html>
<html lang="de">
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#FAFAF9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1A1A1A;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;padding:32px 16px;">
<tr><td align="center">
    <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#FFFFFF;border:1px solid #E5E5E0;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:32px 32px 24px 32px;">
            <h1 style="margin:0 0 16px 0;font-size:20px;font-weight:700;color:#000000;line-height:1.3;">
                Hallo {{ genehmiger.display_name|split(' ')|first }},
            </h1>
            <p style="margin:0 0 24px 0;font-size:15px;line-height:1.6;color:#1A1A1A;">
                <strong>{{ applicant.display_name }}</strong> hat einen Urlaubsantrag eingereicht und dich als Genehmiger:in eingetragen.
            </p>

            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;border:1px solid #E5E5E0;border-radius:8px;margin-bottom:24px;">
                <tr><td style="padding:16px 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                            <td style="font-size:12px;color:#6B6B6B;text-transform:uppercase;letter-spacing:0.05em;padding:6px 0;width:120px;">Zeitraum</td>
                            <td style="font-size:14px;color:#1A1A1A;font-weight:500;padding:6px 0;">{{ absence.startdatum|date('d.m.Y') }} – {{ absence.enddatum|date('d.m.Y') }}</td>
                        </tr>
                        <tr>
                            <td style="font-size:12px;color:#6B6B6B;text-transform:uppercase;letter-spacing:0.05em;padding:6px 0;">Tage</td>
                            <td style="font-size:14px;color:#1A1A1A;font-weight:500;padding:6px 0;">{{ absence.tage_gezaehlt|number_format(1, ',', '.') }}</td>
                        </tr>
                        {% if absence.notiz %}
                        <tr>
                            <td style="font-size:12px;color:#6B6B6B;text-transform:uppercase;letter-spacing:0.05em;padding:6px 0;vertical-align:top;">Notiz</td>
                            <td style="font-size:14px;color:#1A1A1A;padding:6px 0;white-space:pre-line;">{{ absence.notiz }}</td>
                        </tr>
                        {% endif %}
                    </table>
                </td></tr>
            </table>

            <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                    <td style="padding-right:8px;">
                        <a href="{{ approve_url }}" style="display:inline-block;padding:12px 24px;background:#7B9468;color:#FFFFFF;text-decoration:none;font-weight:500;font-size:14px;border-radius:8px;">
                            ✓ Genehmigen
                        </a>
                    </td>
                    <td style="padding-left:8px;">
                        <a href="{{ reject_url }}" style="display:inline-block;padding:12px 24px;background:#FFFFFF;color:#000000;text-decoration:none;font-weight:500;font-size:14px;border:1.5px solid #000000;border-radius:8px;">
                            ✗ Ablehnen
                        </a>
                    </td>
                </tr>
            </table>

            <p style="margin:24px 0 0 0;font-size:12px;color:#6B6B6B;line-height:1.5;text-align:center;">
                Die Links sind 7 Tage gültig (bis {{ expires_at|date('d.m.Y H:i') }}). Jeder Link nur einmal verwendbar.
            </p>
        </td></tr>

        <tr><td style="padding:16px 32px;background:#FAFAF9;border-top:1px solid #E5E5E0;font-size:11px;color:#6B6B6B;line-height:1.5;text-align:center;">
            Diese Mail wurde automatisch von {{ org.short_name }} gesendet.<br>
            Probleme? <a href="mailto:{{ org.support_email }}" style="color:#7B9468;">{{ org.support_email }}</a>
        </td></tr>
    </table>
</td></tr>
</table>
</body>
</html>
