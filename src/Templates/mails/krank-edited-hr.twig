<!DOCTYPE html>
<html lang="{{ current_locale() }}">
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#FAFAF9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1A1A1A;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;padding:32px 16px;">
<tr><td align="center">
    <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#FFFFFF;border:1px solid #E5E5E0;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:32px;">
            <h1 style="margin:0 0 16px 0;font-size:18px;font-weight:700;color:#000000;">Krankmeldung aktualisiert</h1>
            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                {% if editor.id == applicant.id %}
                <strong>{{ applicant.display_name }}</strong> hat seine eigene Krankmeldung bearbeitet.
                {% else %}
                <strong>{{ editor.display_name }}</strong> hat die Krankmeldung von <strong>{{ applicant.display_name }}</strong> bearbeitet.
                {% endif %}
            </p>

            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAFAF9;border-left:3px solid #C9A227;margin-bottom:20px;">
                <tr><td style="padding:14px 18px;">
                    <div style="font-size:12px;color:#6B6B6B;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">Vorher</div>
                    <div style="font-size:14px;color:#1A1A1A;line-height:1.5;">
                        {{ absence_old.startdatum|localized_date }} bis {{ absence_old.enddatum|localized_date }}
                        ({{ absence_old.tage_gezaehlt|number_format(1, ',', '.') }} Tage)
                    </div>
                </td></tr>
            </table>

            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FFF8E7;border-left:3px solid #A0801F;margin-bottom:24px;">
                <tr><td style="padding:14px 18px;">
                    <div style="font-size:12px;color:#A0801F;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">Jetzt</div>
                    <div style="font-size:14px;color:#1A1A1A;line-height:1.5;">
                        {{ absence_new.startdatum|localized_date }} bis {{ absence_new.enddatum|localized_date }}
                        ({{ absence_new.tage_gezaehlt|number_format(1, ',', '.') }} Tage)
                    </div>
                    {% if absence_new.notiz %}
                    <div style="font-size:13px;color:#6B6B6B;margin-top:8px;line-height:1.5;white-space:pre-line;">
                        Notiz: {{ absence_new.notiz }}
                    </div>
                    {% endif %}
                </td></tr>
            </table>

            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                Der Gruppenkalender wurde entsprechend aktualisiert.
            </p>
        </td></tr>

        <tr><td style="padding:16px 32px;background:#FAFAF9;border-top:1px solid #E5E5E0;font-size:11px;color:#6B6B6B;line-height:1.5;text-align:center;">
            {{ org.short_name }} · {{ org.legal_name }}
        </td></tr>
    </table>
</td></tr>
</table>
</body>
</html>
