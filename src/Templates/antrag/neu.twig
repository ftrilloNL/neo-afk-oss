{% extends 'layout.twig' %}
{% block title %}Urlaub beantragen – {{ org.short_name }}{% endblock %}
{% block content %}

<div class="flex items-center gap-3 mb-8">
    <a href="/" class="text-gray-500 hover:text-black p-1.5 rounded-md hover:bg-gray-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-2xl font-bold tracking-tight">Urlaub beantragen</h1>
</div>

{% if flash_error %}
<div class="mb-6 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-800 max-w-3xl">
    {{ flash_error }}
</div>
{% endif %}

<form method="post" action="/antrag" class="max-w-3xl space-y-6">
    {{ csrf_field() }}

    {# Zeitraum #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-4">Zeitraum</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Von</label>
                <div class="flex gap-2">
                    <input type="date" name="startdatum" value="{{ today }}" required
                        class="flex-1 px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
                    <select name="halbtag_start"
                        class="px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
                        <option value="ganztag">Ganztag</option>
                        <option value="nachmittag">ab Nachmittag</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Bis</label>
                <div class="flex gap-2">
                    <input type="date" name="enddatum" value="{{ today }}" required
                        class="flex-1 px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
                    <select name="halbtag_ende"
                        class="px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
                        <option value="ganztag">Ganztag</option>
                        <option value="vormittag">bis Mittag</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="mt-4 px-4 py-3 bg-sage-50 border border-sage-200 rounded-md"
             id="tage-preview"
             hx-get="/antrag/preview-tage?art=urlaub"
             hx-trigger="load, change from:closest form"
             hx-include="[name='startdatum'],[name='enddatum'],[name='halbtag_start'],[name='halbtag_ende']"
             hx-swap="innerHTML">
            <div class="text-sm text-gray-400">Werktage werden nach Eingabe beider Daten angezeigt</div>
        </div>
        <p class="text-xs text-gray-500 mt-3">
            Werktage berücksichtigen Berliner Feiertage und Halbtag-Korrektur.
        </p>
    </div>

    {# Genehmiger #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-4">Genehmiger:in</h2>
        <select name="genehmiger_id" required
            class="w-full px-3 py-2.5 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
            <option value="">– Wählen –</option>
            {% for g in genehmiger_options %}
                {% if g.id != user.id %}
                <option value="{{ g.id }}">{{ g.display_name }} · {{ g.email }}</option>
                {% endif %}
            {% endfor %}
        </select>
    </div>

    {# Notiz #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-4">Notiz <span class="font-normal text-gray-500">(optional, nur für Genehmiger:in sichtbar)</span></h2>
        <textarea name="notiz" rows="3" placeholder="z.B. Vertretung, Urlaubsgrund …"
            class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 resize-none"></textarea>
    </div>

    {# Out-of-Office-Text(e) — bei Microsoft zwei Felder (Gmail hat keine
       Trennung intern/extern und unterstuetzt nur einen Body pro Vacation). #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-2">Out-of-Office-Nachricht</h2>
        <p class="text-xs text-gray-500 mb-4">Wird beim Approval automatisch gesetzt — Zeitraum entspricht dem Urlaub oben. Texte je Antrag individuell, weil Vertretung und Kontext oft variieren.</p>
        {% if org.identity_provider == 'google' %}
            <textarea name="ooo_text" rows="6"
                placeholder="Liebe Grüße, ich bin im Urlaub und melde mich am … zurück. In dringenden Fällen wendet euch an …"
                class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500"></textarea>
        {% else %}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1.5">Interne Antwort (Kolleg:innen)</label>
                    <textarea name="ooo_internal" rows="6"
                        placeholder="Liebe Kolleg:innen, ich bin im Urlaub und melde mich am … zurück. In dringenden Fällen wendet euch an …"
                        class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1.5">Externe Antwort (alle anderen)</label>
                    <textarea name="ooo_external" rows="6"
                        placeholder="Thank you for your message. I am out of office until … and will reply upon my return. For urgent matters please contact …"
                        class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500"></textarea>
                </div>
            </div>
        {% endif %}
    </div>

    {# Resturlaub-Hinweis #}
    <div class="bg-sage-50 border border-sage-200 rounded-xl p-5">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-sage-700 mb-1">Verfügbarer Resturlaub</div>
                <div class="text-2xl font-bold tabular text-sage-900">
                    {{ ((user.resturlaub_aktuell + user.resturlaub_vorjahr))|number_format(1, ',', '.') }} Tage
                </div>
            </div>
            <div class="text-xs text-sage-700 text-right">
                {{ user.resturlaub_aktuell|number_format(1, ',', '.') }} aktuell<br>
                + {{ user.resturlaub_vorjahr|number_format(1, ',', '.') }} Vorjahr (verfällt 31.03.)
            </div>
        </div>
    </div>

    {# Footer #}
    <div class="flex items-center justify-between pt-2">
        <a href="/" class="px-5 py-2.5 text-sm font-medium border border-black rounded-md hover:bg-gray-50 transition-colors">
            Abbrechen
        </a>
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-medium bg-sage-500 text-white rounded-md hover:bg-sage-600 transition-colors">
            Antrag einreichen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
    </div>

</form>

{% endblock %}
