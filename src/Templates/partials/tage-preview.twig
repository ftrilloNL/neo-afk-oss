{# Wird via HTMX bei jedem Datums-/Halbtag-Change geladen. Erwartet:
   state ∈ {incomplete, invalid, invalid_range, ok}, tage, verfuegbar (nullable), ueberzogen (bool), art #}
{% if state == 'ok' %}
    <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1">
        <div class="text-sm">
            <span class="font-bold tabular text-base">{{ tage|number_format(1, ',', '.') }}</span>
            {{ (tage == 1.0 ? 'antrag.preview.werktag_one' : 'antrag.preview.werktag_many')|trans }}
        </div>
        {% if art == 'urlaub' and verfuegbar is not null %}
            {% if ueberzogen %}
                <div class="text-sm text-red-700">
                    {{ 'antrag.preview.exceeds'|trans({'%n%': verfuegbar|number_format(1, ',', '.')}) }}
                </div>
            {% else %}
                <div class="text-sm text-gray-500">
                    {{ 'antrag.preview.of_available'|trans({'%n%': verfuegbar|number_format(1, ',', '.')}) }}
                </div>
            {% endif %}
        {% endif %}
    </div>
{% elseif state == 'invalid_range' %}
    <div class="text-sm text-red-700">{{ 'antrag.preview.invalid_range'|trans }}</div>
{% elseif state == 'invalid' %}
    <div class="text-sm text-gray-500">{{ 'antrag.preview.invalid'|trans }}</div>
{% else %}
    <div class="text-sm text-gray-400">{{ 'antrag.preview.placeholder'|trans }}</div>
{% endif %}
