{% extends 'layout.twig' %}
{% import 'macros/status.twig' as status %}
{% set active_nav = 'home' %}
{% block title %}Übersicht – {{ org.short_name }}{% endblock %}
{% block content %}

{% set total_resturlaub = (user.resturlaub_aktuell + user.resturlaub_vorjahr) %}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-6 md:mb-8">
    <h1 class="text-2xl font-bold tracking-tight">Hallo {{ user.display_name|split(' ')|first }} 👋</h1>
    <div class="text-sm text-gray-500 px-3 py-1.5 border border-card-border rounded-full self-start sm:self-auto">
        {{ monat_jahr_de() }}
    </div>
</div>

{% if flash_success %}
<div class="mb-6 px-4 py-3 rounded-md bg-sage-50 border border-sage-200 text-sm text-sage-900 flex items-center gap-2">
    <svg class="w-4 h-4 shrink-0 text-sage-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
    {{ flash_success }}
</div>
{% endif %}
{% if flash_error %}
<div class="mb-6 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-800 flex items-center gap-2">
    <svg class="w-4 h-4 shrink-0 text-red-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 9v4M12 17h.01M21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/></svg>
    {{ flash_error }}
</div>
{% endif %}

{# Hero: Resturlaub #}
<div class="bg-sage-500 rounded-xl text-white p-6 md:p-8 mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">
    <div>
        <div class="text-sm font-medium opacity-80 mb-3">Mein Resturlaub</div>
        <div class="flex items-baseline gap-2 tabular">
            <div class="text-6xl font-bold tracking-tight">{{ user.resturlaub_aktuell|number_format(1, ',', '.') }}</div>
            <div class="text-2xl opacity-90">Tage</div>
        </div>
        {% if user.resturlaub_vorjahr > 0 %}
        <div class="text-sm opacity-80 mt-3">
            + {{ user.resturlaub_vorjahr|number_format(1, ',', '.') }} Tage aus Vorjahr
            <span class="opacity-70">(verfallen 31.03.{{ "now"|date("Y")|number_format(0, '.', '') + 1 }})</span>
        </div>
        {% endif %}
    </div>
    <div class="flex flex-wrap gap-2 sm:justify-end">
        <a href="/antrag/neu" class="inline-flex items-center gap-2 bg-white text-sage-700 px-5 py-2.5 rounded-md font-medium hover:bg-sage-50 transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            Urlaub beantragen
        </a>
        <a href="/krank/neu" class="inline-flex items-center gap-2 bg-transparent text-white border border-white/40 hover:bg-white/10 px-5 py-2.5 rounded-md font-medium transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2v6h6M4 13.5V4a2 2 0 0 1 2-2h8l6 6v11.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M11 14h2v6h-2zM8 17h8"/></svg>
            Krankmeldung
        </a>
        {% if pending_approvals_count is defined and pending_approvals_count > 0 %}
        <a href="/genehmigungen" class="inline-flex items-center gap-2 bg-transparent text-white border border-white/40 hover:bg-white/10 px-5 py-2.5 rounded-md font-medium transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            Genehmigungen ({{ pending_approvals_count }})
        </a>
        {% endif %}
    </div>
</div>

{# Three Metric Cards #}
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    <div class="bg-white border border-card-border rounded-xl p-5">
        <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-3">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            Jahresanspruch
        </div>
        <div class="text-3xl font-bold tabular">{{ user.jahresanspruch }},0 <span class="text-base font-normal text-gray-500">Tage</span></div>
        <div class="text-xs text-gray-500 mt-1">{{ user.eintrittsdatum ? 'seit ' ~ user.eintrittsdatum|date('d.m.Y') : 'pro Kalenderjahr' }}</div>
    </div>

    <div class="bg-white border border-card-border rounded-xl p-5">
        <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-3">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s-8-4-8-12V5l8-3 8 3v5c0 8-8 12-8 12z"/></svg>
            Verfügbar gesamt
        </div>
        <div class="text-3xl font-bold tabular">{{ total_resturlaub|number_format(1, ',', '.') }} <span class="text-base font-normal text-gray-500">Tage</span></div>
        <div class="text-xs text-gray-500 mt-1">{{ user.resturlaub_aktuell|number_format(1, ',', '.') }} aktuell + {{ user.resturlaub_vorjahr|number_format(1, ',', '.') }} Vorjahr</div>
    </div>

    <div class="bg-white border border-card-border rounded-xl p-5">
        <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-3">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            Krank-Tage {{ "now"|date("Y") }}
        </div>
        <div class="text-3xl font-bold tabular">{{ (krank_tage_ytd ?? 0)|number_format(1, ',', '.') }} <span class="text-base font-normal text-gray-500">Tage</span></div>
        <div class="text-xs text-gray-500 mt-1">Im Kalender nur als „Abwesend" — Detail nur du + HR sichtbar</div>
    </div>
</div>

{# Abwesenheiten table #}
<div class="bg-white border border-card-border rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-card-border">
        <h2 class="font-semibold">Meine Abwesenheiten</h2>
    </div>

    {% if absences is defined and absences|length > 0 %}
    <div class="overflow-x-auto"><table class="w-full text-sm">
        <thead>
            <tr class="text-[10px] font-semibold uppercase tracking-wider text-gray-500 border-b border-card-border">
                <th class="text-left px-5 py-3">Typ</th>
                <th class="text-left px-5 py-3">Zeitraum</th>
                <th class="text-left px-5 py-3 tabular">Tage</th>
                <th class="text-left px-5 py-3">Status</th>
                <th class="text-right px-5 py-3"></th>
            </tr>
        </thead>
        <tbody>
            {% for a in absences %}
            <tr class="border-b border-card-border last:border-0 hover:bg-gray-50">
                <td class="px-5 py-3.5">
                    {% if a.art == 'urlaub' %}
                        <span class="inline-flex items-center gap-2"><span class="text-base">🌴</span> Urlaub</span>
                    {% else %}
                        <span class="inline-flex items-center gap-2"><span class="text-base">🤒</span> Krank</span>
                    {% endif %}
                </td>
                <td class="px-5 py-3.5 tabular">{{ a.startdatum|date('d.m.') }}–{{ a.enddatum|date('d.m.Y') }}</td>
                <td class="px-5 py-3.5 tabular font-medium">{{ a.tage_gezaehlt|number_format(1, ',', '.') }}</td>
                <td class="px-5 py-3.5">
                    {{ status.pill(a.art, a.status) }}
                </td>
                <td class="px-5 py-3.5 text-right">
                    {% if a.status in ['beantragt', 'aktiv'] %}
                    <form method="post" action="/antrag/{{ a.id }}/storno" class="inline" onsubmit="return confirm('Diesen Antrag wirklich stornieren?');">
                        {{ csrf_field() }}
                        <button type="submit" class="text-xs text-gray-500 hover:text-red-700 underline underline-offset-2">Stornieren</button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table></div>
    {% else %}
    <div class="p-12 text-center">
        <div class="text-gray-500 text-sm mb-3">Noch keine Abwesenheiten erfasst.</div>
        <a href="/antrag/neu" class="inline-flex items-center gap-2 text-sm text-sage-700 font-medium hover:text-sage-800 underline underline-offset-2">
            Ersten Antrag stellen
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
    </div>
    {% endif %}
</div>

{% endblock %}
