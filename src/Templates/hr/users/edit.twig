{% extends 'layout.twig' %}
{% set active_nav = 'hr-users' %}
{% block title %}{{ target.display_name }} – {{ org.short_name }}{% endblock %}
{% block content %}

<div class="mb-6">
    <a href="/hr/users" class="text-xs text-gray-500 hover:text-black inline-flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
        {{ 'common.back_to_home'|trans }}
    </a>
    <h1 class="text-2xl font-bold tracking-tight mt-2">{{ target.display_name }}</h1>
    <p class="text-sm text-gray-500 mt-1">{{ target.email }}</p>
</div>

{% if errors|length > 0 %}
<div class="bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-3 mb-6 text-sm">
    {{ 'hr.users.errors.summary'|trans }}
</div>
{% endif %}

<form method="post" action="/hr/users/{{ target.id }}" class="bg-white border border-card-border rounded-xl p-6 max-w-2xl">
    {{ csrf_field() }}

    <div class="mb-5">
        <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'profil.field.job_title'|trans }}</label>
        <input type="text" name="job_title" maxlength="100"
            value="{{ form.job_title ?? (target.job_title ?? '') }}"
            placeholder="{{ 'hr.users.field.job_title.placeholder'|trans }}"
            class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'profil.field.eintrittsdatum'|trans }}</label>
            <input type="date" name="eintrittsdatum"
                value="{{ form.eintrittsdatum ?? (target.eintrittsdatum ?? '') }}"
                class="w-full px-3 py-2 text-sm border {{ errors.eintrittsdatum is defined ? 'border-red-300' : 'border-card-border' }} rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
            {% if errors.eintrittsdatum is defined %}<div class="text-xs text-red-600 mt-1">{{ errors.eintrittsdatum }}</div>{% endif %}
        </div>
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'hr.users.field.jahresanspruch'|trans }}</label>
            <input type="number" name="jahresanspruch" min="0" max="99" step="1"
                value="{{ form.jahresanspruch ?? target.jahresanspruch }}"
                class="w-full px-3 py-2 text-sm border {{ errors.jahresanspruch is defined ? 'border-red-300' : 'border-card-border' }} rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 tabular">
            {% if errors.jahresanspruch is defined %}<div class="text-xs text-red-600 mt-1">{{ errors.jahresanspruch }}</div>{% endif %}
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'profil.urlaub.aktuell'|trans }}</label>
            <input type="text" name="resturlaub_aktuell" inputmode="decimal"
                value="{{ form.resturlaub_aktuell ?? (target.resturlaub_aktuell|number_format(1, ',', '')) }}"
                class="w-full px-3 py-2 text-sm border {{ errors.resturlaub_aktuell is defined ? 'border-red-300' : 'border-card-border' }} rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 tabular">
            <div class="text-xs text-gray-500 mt-1">{{ 'hr.users.edit.field.resturlaub.hint'|trans }}</div>
            {% if errors.resturlaub_aktuell is defined %}<div class="text-xs text-red-600 mt-1">{{ errors.resturlaub_aktuell }}</div>{% endif %}
        </div>
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'profil.urlaub.vorjahr'|trans }}</label>
            <input type="text" name="resturlaub_vorjahr" inputmode="decimal"
                value="{{ form.resturlaub_vorjahr ?? (target.resturlaub_vorjahr|number_format(1, ',', '')) }}"
                class="w-full px-3 py-2 text-sm border {{ errors.resturlaub_vorjahr is defined ? 'border-red-300' : 'border-card-border' }} rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 tabular">
            {% if errors.resturlaub_vorjahr is defined %}<div class="text-xs text-red-600 mt-1">{{ errors.resturlaub_vorjahr }}</div>{% endif %}
        </div>
    </div>

    <div class="border-t border-card-border pt-5 mb-6">
        <div class="text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-3">{{ 'hr.users.edit.section.personal'|trans }}</div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-4">
            <div>
                <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'profil.field.geburtsdatum'|trans }}</label>
                <input type="date" name="geburtsdatum"
                    value="{{ form.geburtsdatum ?? (master.geburtsdatum ?? '') }}"
                    class="w-full px-3 py-2 text-sm border {{ errors.geburtsdatum is defined ? 'border-red-300' : 'border-card-border' }} rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
                {% if errors.geburtsdatum is defined %}<div class="text-xs text-red-600 mt-1">{{ errors.geburtsdatum }}</div>{% endif %}
            </div>
            <div>
                <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'profil.field.telefon'|trans }}</label>
                <input type="tel" name="telefon"
                    value="{{ form.telefon ?? (master.telefon ?? '') }}"
                    class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
            <div class="col-span-3">
                <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'hr.users.field.strasse'|trans }}</label>
                <input type="text" name="strasse"
                    value="{{ form.strasse ?? (master.strasse ?? '') }}"
                    class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
            </div>
            <div>
                <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'hr.users.field.plz'|trans }}</label>
                <input type="text" name="plz" maxlength="10"
                    value="{{ form.plz ?? (master.plz ?? '') }}"
                    class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 tabular">
            </div>
            <div class="col-span-2">
                <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'hr.users.field.ort'|trans }}</label>
                <input type="text" name="ort"
                    value="{{ form.ort ?? (master.ort ?? '') }}"
                    class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
            </div>
        </div>
    </div>

    <div class="border-t border-card-border pt-5 mb-6">
        <div class="text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-3">{{ 'hr.users.roles_status.heading'|trans }}</div>
        <div class="space-y-2.5">
            <label class="flex items-center gap-2.5 text-sm cursor-pointer">
                <input type="checkbox" name="ist_aktiv" value="1"
                    {{ (form is defined and form.ist_aktiv is defined ? form.ist_aktiv : target.ist_aktiv) ? 'checked' : '' }}
                    class="w-4 h-4 rounded border-card-border text-sage-500 focus:ring-sage-500">
                <span>{{ 'hr.users.role.aktiv.label'|trans }}</span>
            </label>
            <label class="flex items-center gap-2.5 text-sm cursor-pointer">
                <input type="checkbox" name="ist_genehmiger" value="1"
                    {{ (form is defined and form.ist_genehmiger is defined ? form.ist_genehmiger : target.ist_genehmiger) ? 'checked' : '' }}
                    class="w-4 h-4 rounded border-card-border text-sage-500 focus:ring-sage-500">
                <span>{{ 'hr.users.role.genehmiger.label'|trans }}</span>
            </label>
            <label class="flex items-center gap-2.5 text-sm cursor-pointer">
                <input type="checkbox" name="ist_hr" value="1"
                    {{ (form is defined and form.ist_hr is defined ? form.ist_hr : target.ist_hr) ? 'checked' : '' }}
                    class="w-4 h-4 rounded border-card-border text-sage-500 focus:ring-sage-500">
                <span>{{ 'hr.users.role.hr.label'|trans }}</span>
            </label>
        </div>
    </div>

    <div class="flex items-center justify-end gap-2">
        <a href="/hr/users" class="text-sm px-4 py-2 border border-card-border rounded-full hover:bg-gray-50">{{ 'action.cancel'|trans }}</a>
        <button type="submit" class="text-sm px-5 py-2 bg-sage-500 text-white rounded-full hover:bg-sage-600">{{ 'action.save'|trans }}</button>
    </div>
</form>

{% endblock %}
