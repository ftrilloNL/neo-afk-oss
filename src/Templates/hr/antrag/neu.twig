{% extends 'layout.twig' %}
{% block title %}Urlaub für MA erfassen – {{ org.short_name }}{% endblock %}
{% block content %}

<div class="flex items-center gap-3 mb-8">
    <a href="/hr" class="text-gray-500 hover:text-black p-1.5 rounded-md hover:bg-gray-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <div>
        <h1 class="text-2xl font-bold tracking-tight">Urlaub für Mitarbeiter:in erfassen</h1>
        <p class="text-sm text-gray-500 mt-0.5">Urlaub wird sofort als genehmigt eingetragen — kein Genehmigungsworkflow.</p>
    </div>
</div>

{% if flash_error %}
<div class="mb-6 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-800 max-w-3xl">
    {{ flash_error }}
</div>
{% endif %}

<form method="post" action="/hr/antrag" class="max-w-3xl space-y-6">
    {{ csrf_field() }}

    {# Mitarbeiter:in auswählen #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-4">Für wen?</h2>
        <select name="fuer_user_id" required
            class="w-full px-3 py-2.5 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white"
            id="fuer_user_id">
            <option value="">– Mitarbeiter:in auswählen –</option>
            {% for u in all_users %}
            <option value="{{ u.id }}" {{ form and form.fuer_user_id == u.id ? 'selected' : '' }}>
                {{ u.display_name }} · {{ u.email }}
            </option>
            {% endfor %}
        </select>
    </div>

    {# Zeitraum #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-4">Zeitraum</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Von</label>
                <div class="flex gap-2">
                    <input type="date" name="startdatum" value="{{ form ? form.startdatum : today }}" required
                        class="flex-1 px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
                    <select name="halbtag_start"
                        class="px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
                        <option value="ganztag" {{ form and form.halbtag_start == 'ganztag' ? 'selected' : '' }}>Ganztag</option>
                        <option value="nachmittag" {{ form and form.halbtag_start == 'nachmittag' ? 'selected' : '' }}>ab Nachmittag</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Bis</label>
                <div class="flex gap-2">
                    <input type="date" name="enddatum" value="{{ form ? form.enddatum : today }}" required
                        class="flex-1 px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
                    <select name="halbtag_ende"
                        class="px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
                        <option value="ganztag" {{ form and form.halbtag_ende == 'ganztag' ? 'selected' : '' }}>Ganztag</option>
                        <option value="vormittag" {{ form and form.halbtag_ende == 'vormittag' ? 'selected' : '' }}>bis Mittag</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="mt-4 px-4 py-3 bg-sage-50 border border-sage-200 rounded-md"
             id="tage-preview"
             hx-get="/hr/antrag/preview-tage?art=urlaub"
             hx-trigger="load, change from:closest form"
             hx-include="[name='startdatum'],[name='enddatum'],[name='halbtag_start'],[name='halbtag_ende'],[name='fuer_user_id']"
             hx-swap="innerHTML">
            <div class="text-sm text-gray-400">Mitarbeiter:in und Daten wählen für Werktage-Vorschau</div>
        </div>
        <p class="text-xs text-gray-500 mt-3">
            Werktage berücksichtigen Berliner Feiertage und Halbtag-Korrektur. Resturlaub wird aus dem Profil des/der Mitarbeiter:in gelesen.
        </p>
    </div>

    {# Notiz #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-4">Notiz <span class="font-normal text-gray-500">(optional, intern)</span></h2>
        <textarea name="notiz" rows="3" placeholder="z.B. Grund der HR-Erfassung, Vertretung …"
            class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 resize-none">{{ form ? form.notiz : '' }}</textarea>
    </div>

    {# Out-of-Office #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-2">Out-of-Office-Nachricht</h2>
        <p class="text-xs text-gray-500 mb-4">Wird sofort für den/die Mitarbeiter:in gesetzt — leer lassen um keinen OOO zu setzen.</p>
        {% if org.identity_provider == 'google' %}
            <textarea name="ooo_text" rows="6"
                placeholder="Liebe Grüße, ich bin im Urlaub und melde mich am … zurück. In dringenden Fällen wendet euch an …"
                class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">{{ form ? form.ooo_text : '' }}</textarea>
        {% else %}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1.5">Interne Antwort (Kolleg:innen)</label>
                    <textarea name="ooo_internal" rows="6"
                        placeholder="Liebe Kolleg:innen, ich bin im Urlaub und melde mich am … zurück. In dringenden Fällen wendet euch an …"
                        class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">{{ form ? form.ooo_internal : '' }}</textarea>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1.5">Externe Antwort (alle anderen)</label>
                    <textarea name="ooo_external" rows="6"
                        placeholder="Thank you for your message. I am out of office until … and will reply upon my return. For urgent matters please contact …"
                        class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">{{ form ? form.ooo_external : '' }}</textarea>
                </div>
            </div>
        {% endif %}
    </div>

    {# Benachrichtigung #}
    <div class="bg-white border border-card-border rounded-xl p-6">
        <h2 class="font-semibold text-base mb-3">Mitarbeiter:in benachrichtigen</h2>
        <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="send_notification" value="1"
                {{ form and form.send_notification ? 'checked' : '' }}
                class="mt-0.5 rounded border-card-border text-sage-500 focus:ring-sage-500">
            <span class="text-sm text-gray-700">Info-Mail an Mitarbeiter:in senden — enthält Zeitraum und Notiz, keine Genehmigungslinks.</span>
        </label>
    </div>

    {# Footer #}
    <div class="flex items-center justify-between pt-2">
        <a href="/hr" class="px-5 py-2.5 text-sm font-medium border border-black rounded-md hover:bg-gray-50 transition-colors">
            Abbrechen
        </a>
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-medium bg-sage-500 text-white rounded-md hover:bg-sage-600 transition-colors">
            Urlaub erfassen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
    </div>

</form>

{% endblock %}
