{% extends 'layout.twig' %}
{% set active_nav = 'hr-audit' %}
{% block title %}{{ 'audit.title'|trans }} – {{ org.short_name }}{% endblock %}

{# Formatiert einen Payload-Wert menschlich: true/false → Ja/Nein, NULL → —, ISO-Datum → dd.mm.yyyy. #}
{# Reihenfolge: Bools zuerst, weil PHP-loose-compare false == '' ergibt true. #}
{% macro fmt(value) %}
    {%- if value is same as(true) -%}
        <span class="text-sage-700">{{ 'audit.fmt.yes'|trans }}</span>
    {%- elseif value is same as(false) -%}
        <span class="text-gray-500">{{ 'audit.fmt.no'|trans }}</span>
    {%- elseif value is null or value is same as('') -%}
        <span class="text-gray-400">—</span>
    {%- elseif value is iterable -%}
        <code class="text-[10px] text-gray-600">{{ value|json_encode }}</code>
    {%- elseif value matches '/^\\d{4}-\\d{2}-\\d{2}$/' -%}
        {{ value|date('d.m.Y') }}
    {%- else -%}
        {{ value }}
    {%- endif -%}
{% endmacro %}

{% block content %}

<div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight">{{ 'audit.title'|trans }}</h1>
    <p class="text-sm text-gray-500 mt-1">{{ 'audit.subtitle'|trans({'%count%': entries|length}) }}</p>
</div>

{# Filter-Bar #}
<form method="get" action="/hr/audit" class="bg-white border border-card-border rounded-xl p-5 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 items-end">
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'audit.filter.action'|trans }}</label>
            <select name="action" class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
                <option value="">{{ 'hr.filter.all'|trans }}</option>
                {% for a in all_actions %}
                <option value="{{ a }}" {{ filters.action == a ? 'selected' : '' }}>{{ ('audit.action.' ~ a)|trans }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'audit.filter.actor'|trans }}</label>
            <select name="user_id" class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500 bg-white">
                <option value="">{{ 'hr.filter.all'|trans }}</option>
                {% for u in all_users %}
                <option value="{{ u.id }}" {{ filters.user_id == u.id ? 'selected' : '' }}>{{ u.display_name }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'hr.filter.from'|trans }}</label>
            <input type="date" name="from" value="{{ filters.from }}"
                class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
        </div>
        <div>
            <label class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5">{{ 'hr.filter.to'|trans }}</label>
            <input type="date" name="to" value="{{ filters.to }}"
                class="w-full px-3 py-2 text-sm border border-card-border rounded-md focus:outline-none focus:ring-1 focus:ring-sage-500 focus:border-sage-500">
        </div>
    </div>
    <div class="flex items-center justify-end gap-2 mt-4">
        <a href="/hr/audit" class="text-xs px-3 py-1.5 border border-card-border rounded-full hover:bg-gray-50">{{ 'hr.filter.reset'|trans }}</a>
        <button type="submit" class="text-xs px-4 py-1.5 bg-sage-500 text-white rounded-full hover:bg-sage-600">{{ 'hr.filter.apply'|trans }}</button>
    </div>
</form>

{# Tabelle #}
<div class="bg-white border border-card-border rounded-xl overflow-hidden">
    {% if entries|length == 0 %}
    <div class="p-12 text-center text-sm text-gray-500">
        {{ 'audit.empty'|trans }}
    </div>
    {% else %}
    <div class="overflow-x-auto"><table class="w-full text-sm">
        <thead>
            <tr class="text-[10px] font-semibold uppercase tracking-wider text-gray-500 border-b border-card-border">
                <th class="text-left px-5 py-3">{{ 'audit.col.timestamp'|trans }}</th>
                <th class="text-left px-5 py-3">{{ 'audit.col.actor'|trans }}</th>
                <th class="text-left px-5 py-3">{{ 'audit.col.action'|trans }}</th>
                <th class="text-left px-5 py-3">{{ 'audit.col.target'|trans }}</th>
                <th class="text-left px-5 py-3">{{ 'audit.col.details'|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for e in entries %}
            <tr class="border-b border-card-border last:border-0 hover:bg-gray-50 align-top">
                <td class="px-5 py-3 tabular text-xs whitespace-nowrap">
                    {{ e.created_at|date('d.m.Y') }}<br>
                    <span class="text-gray-500">{{ e.created_at|date('H:i:s') }}</span>
                </td>
                <td class="px-5 py-3 text-xs">
                    {% if e.actor_display_name %}
                        {{ e.actor_display_name }}
                    {% else %}
                        <span class="text-gray-400 italic">{{ 'audit.system_actor'|trans }}</span>
                    {% endif %}
                </td>
                <td class="px-5 py-3">
                    <span class="text-sm">{{ ('audit.action.' ~ e.action)|trans }}</span>
                </td>
                <td class="px-5 py-3 text-xs tabular">
                    {% if e.entity_type == 'user' %}
                        <a href="/hr/users/{{ e.entity_id }}/edit" class="hover:underline">User #{{ e.entity_id }}</a>
                    {% else %}
                        {{ e.entity_type }} #{{ e.entity_id }}
                    {% endif %}
                </td>
                <td class="px-5 py-3">
                    {% import _self as m %}
                    {% if e.payload_decoded is null %}
                        <span class="text-gray-400 text-xs">—</span>
                    {% elseif e.payload_decoded.before is defined and e.payload_decoded.after is defined %}
                        {# Diff-Tabelle: vorher/nachher, geänderte Felder hervorgehoben #}
                        <details class="text-xs">
                            <summary class="cursor-pointer text-gray-500 hover:text-black select-none">{{ 'audit.show_diff'|trans }}</summary>
                            <table class="mt-2 w-full max-w-lg border border-card-border rounded overflow-hidden">
                                <thead>
                                    <tr class="text-[10px] uppercase tracking-wider text-gray-500 bg-gray-50 border-b border-card-border">
                                        <th class="text-left px-3 py-1.5">{{ 'audit.diff.col.field'|trans }}</th>
                                        <th class="text-left px-3 py-1.5">{{ 'audit.diff.col.before'|trans }}</th>
                                        <th class="text-left px-3 py-1.5">{{ 'audit.diff.col.after'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for key, before_val in e.payload_decoded.before %}
                                        {% set after_val = e.payload_decoded.after[key] ?? null %}
                                        {% set changed = before_val != after_val %}
                                        <tr class="border-b border-card-border last:border-0 {{ changed ? 'bg-amber-50' : '' }}">
                                            <td class="px-3 py-1.5 font-medium text-[11px]">{{ ('audit.field.' ~ key)|trans }}</td>
                                            <td class="px-3 py-1.5 text-[11px] {{ changed ? 'text-gray-500 line-through' : 'text-gray-400' }}">{{ m.fmt(before_val) }}</td>
                                            <td class="px-3 py-1.5 text-[11px] {{ changed ? 'font-medium text-sage-800' : 'text-gray-400' }}">{{ m.fmt(after_val) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            {% if e.payload_decoded.master_data is defined %}
                            <div class="mt-3 text-[10px] uppercase tracking-wider text-gray-500">{{ 'audit.master_data.heading'|trans }}</div>
                            <table class="mt-1 w-full max-w-lg border border-card-border rounded overflow-hidden">
                                <tbody>
                                    {% for key, val in e.payload_decoded.master_data %}
                                    <tr class="border-b border-card-border last:border-0">
                                        <td class="px-3 py-1.5 font-medium text-[11px]">{{ ('audit.field.' ~ key)|trans }}</td>
                                        <td class="px-3 py-1.5 text-[11px]">{{ m.fmt(val) }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            {% endif %}
                        </details>
                    {% else %}
                        {# Flache Key/Value-Liste für Payloads ohne before/after-Struktur #}
                        <details class="text-xs">
                            <summary class="cursor-pointer text-gray-500 hover:text-black select-none">{{ 'audit.show_details'|trans }}</summary>
                            <table class="mt-2 w-full max-w-md border border-card-border rounded overflow-hidden">
                                <tbody>
                                    {% for key, val in e.payload_decoded %}
                                    <tr class="border-b border-card-border last:border-0">
                                        <td class="px-3 py-1.5 font-medium text-[11px]">{{ ('audit.field.' ~ key)|trans }}</td>
                                        <td class="px-3 py-1.5 text-[11px]">{{ m.fmt(val) }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </details>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table></div>
    {% endif %}
</div>

{% endblock %}
