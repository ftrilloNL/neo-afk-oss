{% extends 'layout-auth.twig' %}
{% block title %}{{ 'login.title'|trans }} – {{ org.short_name }}{% endblock %}
{% block content %}
<div class="w-full max-w-md">
    {# Logo above card #}
    <div class="flex items-center justify-center gap-2.5 mb-10">
        <img src="{{ org.logo_url }}" alt="{{ org.short_name }}" class="w-8 h-8">
        <span class="font-bold text-lg tracking-tight">{{ org.short_name }}</span>
    </div>

    <div class="bg-white border border-card-border rounded-xl p-10">
        <h1 class="text-3xl font-bold tracking-tight mb-2">{{ 'login.welcome_back'|trans }}</h1>
        <p class="text-gray-600 leading-relaxed mb-8">
            {{ 'login.subtitle'|trans }}
        </p>

        {% if auth_error %}
        <div class="mb-5 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-800">
            {{ 'login.auth_failed'|trans({'%error%': '<strong>' ~ auth_error ~ '</strong>'})|raw }}
        </div>
        {% endif %}

        <a href="/login" class="w-full inline-flex items-center justify-center gap-3 bg-sage-500 hover:bg-sage-600 text-white font-medium px-5 py-3 rounded-md transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg">
                <rect width="10" height="10" x="1"  y="1"  fill="#F25022" />
                <rect width="10" height="10" x="12" y="1"  fill="#7FBA00" />
                <rect width="10" height="10" x="1"  y="12" fill="#00A4EF" />
                <rect width="10" height="10" x="12" y="12" fill="#FFB900" />
            </svg>
            {{ 'login.button_microsoft'|trans }}
        </a>

        <div class="my-6 flex items-center gap-3">
            <div class="flex-1 h-px bg-card-border"></div>
            <span class="text-xs text-gray-400 uppercase tracking-wider">{{ 'common.or'|trans }}</span>
            <div class="flex-1 h-px bg-card-border"></div>
        </div>

        <a href="mailto:{{ org.support_email }}?subject={{ 'login.support_subject'|trans({'%org%': org.short_name})|url_encode }}" class="block text-center text-sm text-gray-600 hover:text-black underline underline-offset-2">
            {{ 'login.contact_it'|trans }}
        </a>
    </div>
</div>
{% endblock %}
