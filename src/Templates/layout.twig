<!DOCTYPE html>
<html lang="{{ current_locale() }}" data-theme="afk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <title>{% block title %}{{ org.short_name }}{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="/assets/app.css">
    <link rel="icon" type="image/svg+xml" href="{{ org.logo_url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/icon-180.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="{{ org.accent_color }}">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="{{ org.short_name }}">
    <script src="https://unpkg.com/htmx.org@1.9.10" defer></script>
    <script src="/assets/mobile.js" defer></script>
</head>
<body class="font-sans antialiased min-h-screen bg-white text-black">

{# Mobile-Top-Bar — nur unter md sichtbar #}
<div class="md:hidden sticky top-0 z-30 flex items-center justify-between bg-white border-b border-card-border px-4 py-3">
    <button data-mobile-open type="button" aria-label="Menü öffnen" class="p-2 -ml-2 text-black">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
    <div class="flex items-center gap-2">
        <img src="{{ org.logo_url }}" alt="{{ org.short_name }}" class="w-6 h-6">
        <span class="font-bold tracking-tight text-sm">{{ org.short_name }}</span>
    </div>
    <div class="w-10"></div>
</div>

{# Backdrop für Mobile-Drawer #}
<div id="mobile-overlay" class="hidden md:hidden fixed inset-0 z-40 bg-black/40"></div>

<div class="flex min-h-screen">
    <aside id="sidebar"
           class="fixed md:static z-50 inset-y-0 left-0 w-64 md:w-60 shrink-0 border-r border-card-border bg-white flex flex-col transform -translate-x-full md:translate-x-0 transition-transform duration-200 ease-out">
        <div class="px-6 pt-6 pb-5 flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <img src="{{ org.logo_url }}" alt="{{ org.short_name }}" class="w-7 h-7">
                <span class="font-bold tracking-tight text-[15px]">{{ org.short_name }}</span>
            </div>
            <button data-mobile-close type="button" aria-label="Menü schließen" class="md:hidden p-1 -mr-1 text-gray-500 hover:text-black">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
        </div>

        <nav class="flex-1 px-3 space-y-0.5">
            <div class="px-3 pt-3 pb-2 text-[10px] font-semibold uppercase tracking-wider text-gray-500">Allgemein</div>

            <a href="/" class="{{ active_nav == 'home' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><path d="M9 22V12h6v10" />
                </svg>
                Übersicht
            </a>

            <a href="/antrag/neu" class="{{ active_nav == 'antrag' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
                </svg>
                Urlaub beantragen
            </a>

            <a href="/krank/neu" class="{{ active_nav == 'krank' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M14 2v6h6M4 13.5V4a2 2 0 0 1 2-2h8l6 6v11.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" /><path d="M11 14h2v6h-2zM8 17h8" />
                </svg>
                Krankmeldung
            </a>

            {% if user.ist_genehmiger %}
            <a href="/genehmigungen" class="{{ active_nav == 'genehmigungen' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="m9 11 3 3L22 4" />
                </svg>
                <span class="flex-1">Meine Genehmigungen</span>
                {% if pending_approvals_count is defined and pending_approvals_count > 0 %}
                <span class="pill bg-sage-500 text-white text-[10px] px-2 py-0.5">{{ pending_approvals_count }}</span>
                {% endif %}
            </a>
            {% endif %}

            <a href="/profil" class="{{ active_nav == 'profil' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />
                </svg>
                Mein Profil
            </a>

            <a href="/team" class="{{ active_nav == 'team' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                Team
            </a>

            {% if user.ist_hr %}
            <div class="px-3 pt-5 pb-2 text-[10px] font-semibold uppercase tracking-wider text-gray-500">Verwaltung</div>

            <a href="/hr" class="{{ active_nav == 'hr' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M3 3v18h18" /><path d="M7 12v5M11 8v9M15 5v12M19 9v8" />
                </svg>
                HR-Auswertung
            </a>

            <a href="/hr/users" class="{{ active_nav == 'hr-users' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                Mitarbeiter
            </a>

            <a href="/hr/audit" class="{{ active_nav == 'hr-audit' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" />
                </svg>
                Audit-Log
            </a>

            <div class="px-3 pt-5 pb-2 text-[10px] font-semibold uppercase tracking-wider text-gray-500">Für Mitarbeiter:innen</div>

            <a href="/hr/antrag/neu" class="{{ active_nav == 'hr-antrag' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4" />
                </svg>
                Urlaub erfassen
            </a>

            <a href="/hr/krank/neu" class="{{ active_nav == 'hr-krank' ? 'nav-item-active' : 'nav-item' }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M14 2v6h6M4 13.5V4a2 2 0 0 1 2-2h8l6 6v11.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" /><path d="M11 14h2v6h-2zM8 17h8" />
                </svg>
                Krankmeldung erfassen
            </a>
            {% endif %}
        </nav>

        <div class="border-t border-card-border p-4">
            <div class="flex items-center gap-3">
                {% if user.has_avatar %}
                <img src="/avatar/{{ user.id }}" alt="{{ user.display_name }}" class="w-9 h-9 shrink-0 rounded-full object-cover">
                {% else %}
                <div class="w-9 h-9 shrink-0 rounded-full bg-sage-500 text-white flex items-center justify-center text-xs font-semibold">
                    {{ user.display_name|split(' ')|map(p => p|first|upper)|join('')|slice(0, 2) }}
                </div>
                {% endif %}
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium truncate">{{ user.display_name }}</div>
                    <div class="text-xs text-gray-500 truncate">{{ user.email }}</div>
                </div>
                <form method="post" action="/logout" class="m-0">
                    {{ csrf_field() }}
                    <button type="submit" title="Logout" class="text-gray-400 hover:text-black p-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" />
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <main class="flex-1 px-4 sm:px-6 md:px-10 py-6 md:py-8 max-w-[1280px] min-w-0">
        {% block content %}{% endblock %}
    </main>
</div>

</body>
</html>
