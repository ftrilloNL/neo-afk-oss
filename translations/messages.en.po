msgid "setup.intro.req4.title"
msgstr "Write access to <code>.env</code> + <code>var/secrets/</code>"

msgid "setup.intro.req4.body"
msgstr "The webserver user must be able to write to these paths — otherwise the wizard cannot persist any values."

msgid "setup.intro.security_warning"
msgstr "<strong>Security note:</strong> this setup is <em>not</em> authenticated. After completion the wizard locks itself (<code>SETUP_MODE=false</code> + lock file). Until then: do not leave it publicly reachable."

