APP_ENV=production
APP_URL=https://afk.example.com
APP_SECRET=change-me-to-random-32-bytes

# Org-Branding — fuer deine eigene Org anpassen.
ORG_NAME=afk
ORG_SHORT_NAME=afk
ORG_LEGAL_NAME=Your Company GmbH
ORG_LOGO_URL=/assets/logo.svg
ORG_SUPPORT_EMAIL=support@example.com
# Hex-Farbe fuer browser-tab-color + PWA-Icon-Theme-Color.
ORG_ACCENT_COLOR_HEX=#3b82f6
ORG_DEFAULT_JAHRESANSPRUCH=30
# Feiertage-Bundesland: ISO-3166-2:DE-Code.
# BE=Berlin (Migration 002 seeded), BY=Bayern (migrations/seeds/feiertage-BY.sql).
# Fuer andere: Seed-File analog anlegen und einspielen.
ORG_FEIERTAGE_BUNDESLAND=BE

# Setup-Diagnose-Page /setup. Nach erfolgreichem Setup auf false setzen — sonst
# leakt eine fremde Person via /setup-Endpoint Konfigurations-Hinweise.
SETUP_MODE=true

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afk
DB_USER=afk
DB_PASS='your-db-password'

# Microsoft Entra ID OAuth — gemeinsame App-Registrierung fuer:
#  - SSO (Delegated): openid, profile, email, offline_access, User.Read
#  - Graph-Calendar (Application, Admin-Konsens): Calendars.ReadWrite
#  - Auto-OOO (Application, Admin-Konsens): MailboxSettings.ReadWrite
#  - SMTP (Delegated, Public-Client-Flow): SMTP.Send (Office 365 Exchange Online)
# Setup-Schritte: docs/entra-id-setup.md
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_TENANT_ID=
OAUTH_REDIRECT_URI=https://afk.example.com/auth/callback

# Microsoft Graph — Email/UPN der Shared Mailbox mit dem geteilten Kalender.
# Die App schreibt Urlaubs- und Krank-Events in deren Calendar.
GRAPH_CALENDAR_USER=urlaub@example.com

# SMTP — XOAUTH2 gegen Office365. Kein Passwort, sondern Refresh-Token unter
# var/secrets/smtp-refresh-token (einmal via `php bin/setup-smtp-oauth.php`
# initialisieren). Setup-Schritte: docs/smtp-setup.md
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=afk

# HR-Verteiler-Mail fuer Krankmeldungs-Benachrichtigungen.
# Mehrere Adressen erlaubt — komma- oder semikolon-separiert.
HR_NOTIFICATION_EMAIL=hr@example.com

# Reminder-Cron — Trigger-Schwellen (Tage). Optional, Defaults sind 2 und 5.
# REMINDER_AFTER_DAYS=2
# REMINDER_REPEAT_AFTER_DAYS=5
