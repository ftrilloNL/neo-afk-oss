{
    "name": "ftrillonl/neo-afk",
    "description": "Self-hostable absence tracking web app (vacation, sick leave, HR analytics) with Microsoft 365 SSO",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.7",
        "league/oauth2-client": "^2.7",
        "monolog/monolog": "^3.5",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^6.9",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "slim/twig-view": "^3.3",
        "symfony/translation": "^7.0",
        "symfony/twig-bridge": "^7.0",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.49",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src --level=8",
        "fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
